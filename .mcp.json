{
  "mcpServers": {
    "cpanel-mcp": {
      "type": "stdio",
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/launch-mcp.sh",
      "args": [],
      "env": {
        "CPANEL_HOST": "${CPANEL_HOST:-}",
        "CPANEL_PORT": "${CPANEL_PORT:-2083}",
        "CPANEL_USER": "${CPANEL_USER:-}",
        "CPANEL_API_KEY": "${CPANEL_API_KEY:-}",
        "CPANEL_INSECURE_TLS": "${CPANEL_INSECURE_TLS:-}"
      }
    }
  }
}
